package com.twitterdev.rdio.app;

/**
 * Copy this file to Constants.java and replace the placeholder values locally.
 * Constants.java is ignored so real Twitter and Rdio credentials stay private.
 */
public final class Constants {
    private Constants() {
    }

    public static final String API_KEY = "YOUR_TWITTER_API_KEY";
    public static final String API_SECRET = "YOUR_TWITTER_API_SECRET";

    public static final String appKey = "YOUR_RDIO_APP_KEY";
    public static final String appSecret = "YOUR_RDIO_APP_SECRET";

    public static final String CALLBACKURL = "app://twitter-dev";
    public static final String URL_TWITTER_OAUTH_VERIFIER = "oauth_verifier";

    public static final String PREF_KEY_OAUTH_TOKEN = "oauth_token";
    public static final String PREF_KEY_OAUTH_SECRET = "oauth_token_secret";
    public static final String PREF_KEY_TWITTER_LOGIN = "is_twitter_logged_in";
}
